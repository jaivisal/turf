datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id            Int    @id @default(autoincrement())
  username      String @unique @db.VarChar(50)
  password_hash String @db.VarChar(255)

  @@map("admin_user")
}

model Booking {
  id             Int      @id @default(autoincrement())
  booking_date   DateTime @db.Date
  start_time     DateTime @db.Time
  end_time       DateTime @db.Time
  duration_hours Decimal  @db.Decimal(3, 1)
  payment_status String   @db.VarChar(20)
  amount_paid    Decimal  @default(0) @db.Decimal(10, 2)
  payment_method String?  @db.VarChar(20)
  payer_name     String   @db.VarChar(100)
  payer_number   String   @db.VarChar(15)
  created_at     DateTime @default(now()) @db.Timestamp
  updated_at     DateTime @default(now()) @db.Timestamp

  @@map("bookings")
}
